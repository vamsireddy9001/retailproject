{
	"name": "csv_df",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv",
						"type": "DatasetReference"
					},
					"name": "csvfile"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_parquet",
						"type": "DatasetReference"
					},
					"name": "goldlayer"
				}
			],
			"transformations": [
				{
					"name": "selectsales"
				}
			],
			"scriptLines": [
				"source(output(",
				"          sale_id as string,",
				"          product_id as string,",
				"          region as string,",
				"          quantity as integer,",
				"          price as integer,",
				"          sale_date as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> csvfile",
				"csvfile select(mapColumn(",
				"          sale_id,",
				"          product_id,",
				"          region",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectsales",
				"selectsales sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> goldlayer"
			]
		}
	}
}